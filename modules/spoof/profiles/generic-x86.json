{
  "name": "Generic x86 (passthrough)",
  "id": "generic-x86",
  "description": "Minimal identity – keeps device props, hides LineageOS/emulator markers",
  "props": {
    "ro.build.tags": "release-keys",
    "ro.build.type": "user",
    "ro.build.version.release": "11",
    "ro.build.version.sdk": "30",
    "ro.vendor.build.tags": "release-keys",
    "ro.vendor.build.type": "user",
    "ro.odm.build.tags": "release-keys",

    "ro.lineage.version": "18.1",
    "ro.lineage.releasetype": "RELEASE",

    "ro.secure": "1",
    "ro.debuggable": "0",
    "ro.build.selinux": "1",
    "ro.secureboot.enable": "1",
    "ro.boot.verifiedbootstate": "green",
    "ro.boot.flash.locked": "1",
    "ro.boot.selinux": "enforcing",
    "ro.kernel.qemu": "0",
    "ro.adb.secure": "1",
    "persist.sys.usb.config": "none",

    "debug.hwui.renderer": "skiagl",
    "debug.egl.hw": "1",
    "debug.composition.type": "gpu",
    "persist.sys.ui.hw": "1",
    "hwui.render_dirty_regions": "false",
    "persist.sys.gpu.force": "1",
    "ro.opengles.version": "196610",
    "ro.hardware.egl": "emulation",
    "persist.graphics.vulkan.disable": "false",
    "persist.vulkan.enabled": "1",
    "persist.sys.sf.color_saturation": "1.1",
    "persist.sys.use_16bpp_alpha": "1",
    "ro.surface_flinger.max_frame_buffer_acquired_buffers": "3"
  }
}
