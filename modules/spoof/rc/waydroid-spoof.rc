# waydroid-spoof.rc – Runtime device identity support
# Placed in /system/etc/init/ by the spoof module installer.
#
# Creates the host-writable spoof directory inside the container's /data.
# Profile switching is handled host-side (set-spoof-profile.sh patches
# build.prop directly — setprop cannot change ro.* properties after boot).

on post-fs-data
    # Ensure the spoof directory exists with correct permissions
    mkdir /data/waydroid-spoof 0750 system system
